---
/** ES — под-страницы 14 услуг направления «Construcción y reformas». */
import Layout from '../../../../layouts/Layout.astro';
import SchemaOrg from '../../../../components/seo/SchemaOrg.astro';
import ServicePage from '../../../../components/sector/ServicePage.astro';
import { sectorServiceSchema } from '../../../../lib/sector-schema';
import { ALL_SERVICES, serviceAlternates } from '../../../../data/sectores/construccion';
import type { SectorService } from '../../../../data/sectores/types';

export function getStaticPaths() {
  return ALL_SERVICES.map((svc) => ({ params: { slug: svc.slug.es }, props: { svc } }));
}

interface Props {
  svc: SectorService;
}
const { svc } = Astro.props;
const alternates = serviceAlternates(svc);
const c = svc.copy.es;
---

<Layout
  lang="es"
  title={c.seo.title}
  description={c.seo.description}
  path={alternates.es}
  alternates={alternates}
>
  <SchemaOrg slot="head" data={sectorServiceSchema('es', svc)} />
  <ServicePage lang="es" svc={svc} />
</Layout>
