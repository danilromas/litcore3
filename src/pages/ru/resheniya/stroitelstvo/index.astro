---
/** RU — лендинг-маркетплейс «Строительство и ремонт» (Промт B, 14.07.2026). */
import Layout from '../../../../layouts/Layout.astro';
import SchemaOrg from '../../../../components/seo/SchemaOrg.astro';
import SectorLanding from '../../../../components/sector/SectorLanding.astro';
import { ROUTES } from '../../../../lib/routes';
import { sectorLandingSchema } from '../../../../lib/sector-schema';
import { CONSTRUCCION_PAGE } from '../../../../data/sectores/construccion-page';

const d = CONSTRUCCION_PAGE.ru;
---

<Layout
  lang="ru"
  title={d.seo.title}
  description={d.seo.description}
  path={ROUTES.construccion.ru!}
  alternates={ROUTES.construccion}
>
  <SchemaOrg slot="head" data={sectorLandingSchema('ru')} />
  <SectorLanding lang="ru" />
</Layout>
