---
/**
 * P24 RU — «Медицина и стоматология» в ките sector-clinicas.html.
 * Тексты — вербатим из content/clinicas/ru.md (сегмент PROVIDER/RELO: русскоязычный приём, CTA Telegram).
 * По md: без тёмной вставки-«филамента», зато с PROVIDER-блоком «Почему сейчас и почему мы»
 * и мостом на /ru/dlya-postavshchikov/ под CTA-полосой.
 */
import Layout from '../../../../layouts/Layout.astro';
import Core from '../../../../components/Core.astro';
import Crumbs from '../../../../components/Crumbs.astro';
import PriceCard from '../../../../components/PriceCard.astro';
import Steps from '../../../../components/Steps.astro';
import Faq from '../../../../components/Faq.astro';
import SchemaOrg from '../../../../components/seo/SchemaOrg.astro';
import { ROUTES } from '../../../../lib/routes';
import { service, faqPage, breadcrumb } from '../../../../lib/schema';
import { CLINICAS_RU as d } from '../../../../data/clinicas';

const path = ROUTES.clinicas.ru!;
const alternates = ROUTES.clinicas;

const serviceSchema = {
  ...service({ name: d.schemaService.name, description: d.schemaService.description, path, lang: 'ru' }),
  serviceType: d.schemaService.serviceType,
  areaServed: 'España',
};
---

<Layout
  lang="ru"
  title={d.seo.title}
  description={d.seo.description}
  path={path}
  alternates={alternates}
>
  <SchemaOrg
    slot="head"
    data={[breadcrumb(d.crumbsSchema), serviceSchema, faqPage(d.schemaFaq)]}
  />

  <div class="page-clinicas">
    <!-- ================= ГЕРОЙ ================= -->
    <section class="section hero" style="position:relative">
      <div class="hero-decor" aria-hidden="true">
        <div class="blob" data-plx="0.06" style="width:520px;height:520px;right:-140px;top:-120px"></div>
        <div class="blob" data-plx="0.10" style="width:260px;height:260px;right:26%;bottom:-80px;background:var(--lc-surface-3)"></div>
        <span class="core" data-plx="0.16" style="--core-size:120px;position:absolute;right:12%;top:22%"><span class="orbit"></span></span>
      </div>
      <div class="container hero-content">
        <Crumbs items={d.crumbs} lang="ru" />
        <h1 class="display">
          {d.hero.h1Pre}<span class="accent-word">{d.hero.h1Accent}</span>{d.hero.h1Post}
        </h1>
        <p class="lead">{d.hero.lead}</p>
        <div class="tag-row">
          {/* TODO: подтвердить Telegram-аккаунт у команды (TELEGRAM_URL в src/config/site.ts) */}
          <a class="btn btn--primary btn--lg" href={d.hero.ctaPrimary.href}>{d.hero.ctaPrimary.label}</a>
          <a class="btn btn--ghost btn--lg" href={d.hero.ctaSecondary.href}>{d.hero.ctaSecondary.label}</a>
        </div>
      </div>
    </section>

    <!-- ================= БОЛИ ================= -->
    <section class="section section--alt section--tight">
      <div class="container">
        <h2 class="display">{d.pains.h2}</h2>
        <div class="grid grid--3" style="margin-top:34px">
          {d.pains.cards.map((card) => (
            <article class="card reveal">
              <h3>{card.title}</h3>
              <p class="muted">{card.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ================= РЕШЕНИЯ: процесс → автоматизация → результат ================= -->
    <section class="section">
      <div class="container">
        <p class="kicker"><Core sm />{d.solutions.kicker}</p>
        <h2 class="display">{d.solutions.h2}</h2>
        <div class="grid grid--2" style="margin-top:34px">
          {d.solutions.cards.map((card) => (
            <article class="card sol reveal">
              <h3>{card.title}</h3>
              <p class="mono sol-k">{d.solutions.labels.proceso}</p>
              <p>{card.proceso}</p>
              <p class="mono sol-k">{d.solutions.labels.automatizacion}</p>
              <p>{card.automatizacion}</p>
              <p class="mono sol-k sol-k--res">{d.solutions.labels.resultado}</p>
              <p>{card.resultado}</p>
              {card.note && <p class="sol-note">{card.note}</p>}
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ================= ПОЧЕМУ СЕЙЧАС И ПОЧЕМУ МЫ (PROVIDER-угол) ================= -->
    <section class="section section--warm section--tight">
      <div class="container" style="max-width:820px">
        <h2 class="display">{d.why.h2}</h2>
        <p class="lead" style="max-width:none">{d.why.text}</p>
      </div>
    </section>

    <!-- ================= КАК ВНЕДРЯЕМ ================= -->
    <section class="section">
      <div class="container">
        <h2 class="display">{d.steps.h2}</h2>
        <div style="margin-top:38px">
          <Steps steps={d.steps.items} />
        </div>
      </div>
    </section>

    <!-- ================= ДЕМО ================= -->
    <section class="section section--warm section--tight" id="demo">
      <div class="container">
        <div class="card demo-card reveal">
          <span class="badge badge--tint">{d.demo.badge}</span>
          <h2 style="font-size:var(--lc-size-h3);margin-top:14px">{d.demo.h2}</h2>
          <div class="chat" aria-label={d.demo.chatAria}>
            {d.demo.chat.map((msg) => (
              <p class:list={['msg', msg.from === 'p' ? 'msg--p' : 'msg--b']}>{msg.text}</p>
            ))}
          </div>
          <p class="demo-disclaimer">{d.demo.disclaimer}</p>
          <div class="tag-row">
            <a class="btn btn--primary" href={d.demo.ctaPrimary.href}>{d.demo.ctaPrimary.label}</a>
            {/* TODO: подтвердить Telegram-аккаунт у команды */}
            <a class="btn btn--ghost" href={d.demo.ctaSecondary.href}>{d.demo.ctaSecondary.label}</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ================= ЦЕНЫ (тизер) ================= -->
    <section class="section">
      <div class="container price-teaser">
        <p class="kicker"><Core sm />{d.pricing.kicker}</p>
        <h2 class="display">{d.pricing.h2}</h2>
        <div class="grid grid--2" style="margin-top:34px">
          {d.pricing.plans.map((plan) => (
            <PriceCard {...plan} />
          ))}
        </div>
        <p class="small muted" style="margin-top:18px">
          {d.pricing.notePre}<a href={d.pricing.noteLink.href}>{d.pricing.noteLink.label}</a>{d.pricing.notePost}
        </p>
      </div>
    </section>

    <!-- ================= FAQ ================= -->
    <section class="section section--alt section--tight">
      <div class="container" style="max-width:820px">
        <h2 class="display">{d.faq.h2}</h2>
        <div style="margin-top:26px">
          {d.faq.items.map((item) => (
            <Faq q={item.q}>
              <p>{item.a}</p>
            </Faq>
          ))}
        </div>
      </div>
    </section>

    <!-- ================= CTA + мост «Для поставщиков» ================= -->
    <section class="section section--tight">
      <div class="container">
        <div class="cta-band">
          <h2 class="display" style="font-size:var(--lc-size-h2)">
            {d.ctaBand.h2Pre}<span class="accent-word">{d.ctaBand.h2Accent}</span>{d.ctaBand.h2Post}
          </h2>
          <div class="tag-row">
            {/* TODO: подтвердить Telegram-аккаунт у команды */}
            <a class="btn btn--primary btn--lg" href={d.ctaBand.primary.href}>{d.ctaBand.primary.label}</a>
            <a
              class="btn btn--ghost btn--lg"
              style="color:var(--lc-bg);border-color:color-mix(in srgb,var(--lc-bg) 40%,transparent)"
              href={d.ctaBand.ghost.href}>{d.ctaBand.ghost.label}</a
            >
          </div>
        </div>
        <p class="small muted" style="margin-top:18px">
          {d.bridge.pre}<a href={d.bridge.link.href}>{d.bridge.link.label}</a>
        </p>
      </div>
    </section>
  </div>
</Layout>

<style is:global>
  /* ---- Специфика страницы (подмножество <style id="page"> sector-clinicas.html, префикс .page-clinicas) ---- */

  /* Решения «процесс → автоматизация → результат» */
  .page-clinicas .sol {
    display: flex;
    flex-direction: column;
  }
  .page-clinicas .sol h3 {
    font-size: 1.15rem;
  }
  .page-clinicas .sol .sol-k {
    margin: 12px 0 2px;
    color: var(--lc-ink-soft);
  }
  .page-clinicas .sol .sol-k--res {
    color: var(--lc-accent-deep);
  }
  .page-clinicas .sol p {
    margin: 0;
    font-size: 0.94rem;
  }
  .page-clinicas .sol .sol-note {
    margin-top: 14px;
    padding-top: 12px;
    border-top: 1px solid var(--lc-line);
    font-size: 0.8rem;
    color: var(--lc-ink-soft);
  }

  /* Демо-карточка */
  .page-clinicas .demo-card {
    max-width: 600px;
    margin-inline: auto;
  }
  .page-clinicas .chat {
    display: grid;
    gap: 10px;
    margin: 20px 0 6px;
  }
  .page-clinicas .msg {
    padding: 11px 15px;
    border-radius: 13px;
    max-width: 86%;
    font-size: 0.93rem;
    margin: 0;
  }
  .page-clinicas .msg--p {
    background: var(--lc-surface-2);
    justify-self: end;
    border-bottom-right-radius: 4px;
  }
  .page-clinicas .msg--b {
    background: var(--lc-accent-tint);
    justify-self: start;
    border-bottom-left-radius: 4px;
  }
  .page-clinicas .demo-disclaimer {
    font-size: 0.8rem;
    color: var(--lc-ink-soft);
    margin: 12px 0 18px;
  }

  /* Тарифы: сетка тизера */
  .page-clinicas .price-teaser {
    max-width: 880px;
    margin-inline: auto;
  }
</style>
