---
/**
 * P22 — Цены RU (/ru/tseny/) по content/precios/ru.md: структура как в precios.html,
 * но БЕЗ блока грантов (единственное упоминание — ответ в FAQ), CTA — Telegram.
 * Канон: от 300 € / от 1 500 € / под задачу.
 */
import Layout from '../../../layouts/Layout.astro';
import Crumbs from '../../../components/Crumbs.astro';
import PriceCard from '../../../components/PriceCard.astro';
import Faq from '../../../components/Faq.astro';
import SchemaOrg from '../../../components/seo/SchemaOrg.astro';
import { ROUTES } from '../../../lib/routes';
import { breadcrumb, faqPage } from '../../../lib/schema';
import { PRECIOS } from '../../../data/precios';

const t = PRECIOS.ru;
---

<Layout
  lang="ru"
  title={t.seo.title}
  description={t.seo.description}
  path={ROUTES.precios.ru!}
  alternates={ROUTES.precios}
>
  <SchemaOrg
    slot="head"
    data={[
      breadcrumb([
        { name: 'Главная', path: '/ru/' },
        { name: 'Цены', path: ROUTES.precios.ru! },
      ]),
      faqPage(t.faq.items),
    ]}
  />

  <div class="page-precios">
    <!-- ГЕРОЙ (компакт) -->
    <section class="section section--tight hero" style="position:relative">
      <div class="hero-decor" aria-hidden="true">
        <div class="blob" data-plx="0.06" style="width:420px;height:420px;right:-120px;top:-140px"></div>
      </div>
      <div class="container hero-content">
        <Crumbs items={t.crumbs} lang="ru" />
        <h1 class="display" set:html={t.hero.h1Html} />
        <p class="lead">{t.hero.lead}</p>
      </div>
    </section>

    <!-- ПАКЕТЫ -->
    <section class="section section--tight">
      <div class="container">
        <div class="grid grid--3" style="align-items:stretch">
          {t.cards.map((card) => (
            <div class="reveal" style="display:grid">
              <PriceCard
                plan={card.plan}
                price={card.price}
                cur={card.cur}
                note={card.note}
                items={card.items}
                cta={card.cta}
                featured={card.featured}
                recommendLabel={t.recommendLabel}
              />
            </div>
          ))}
        </div>
        <p class="muted small" style="margin-top:18px">{t.taxNote}</p>
      </div>
    </section>

    <!-- СРАВНЕНИЕ -->
    <section class="section section--alt">
      <div class="container">
        <h2 class="display">{t.table.h2}</h2>
        <div class="table-wrap" style="margin-top:32px">
          <table class="lc">
            <thead>
              <tr>{t.table.head.map((h) => <th>{h}</th>)}</tr>
            </thead>
            <tbody>
              {t.table.rows.map((row) => (
                <tr>{row.map((cell) => <td>{cell}</td>)}</tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="muted small" style="margin-top:18px">{t.table.foot}</p>
      </div>
    </section>

    <!-- Блока грантов в RU-версии НЕТ (SPEC/P22): гранты не продаём, только ответ в FAQ. -->

    <!-- FAQ -->
    <section class="section section--tight section--alt">
      <div class="container" style="max-width:820px">
        <h2 class="display">{t.faq.h2}</h2>
        {t.faq.items.map((item) => (
          <Faq q={item.q}>
            <p>{item.a}</p>
          </Faq>
        ))}
      </div>
    </section>

    <!-- CTA-ПОЛОСА (Telegram) -->
    <section class="section section--tight">
      <div class="container">
        <div class="cta-band">
          <h2 class="display" set:html={t.cta.h2Html} />
          <div class="tag-row">
            <a class="btn btn--primary btn--lg" href={t.cta.primary.href}>{t.cta.primary.label}</a>
            <a
              class="btn btn--ghost btn--lg"
              style="color:var(--lc-bg);border-color:color-mix(in srgb,var(--lc-bg) 40%,transparent)"
              href={t.cta.secondary.href}>{t.cta.secondary.label}</a>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style is:global>
  /* — страничная специфика цен (перенос из precios.html <style id="page">), префикс .page-precios — */
  .page-precios table.lc td,
  .page-precios .price-card .price{font-variant-numeric:tabular-nums}
  .page-precios table.lc th[scope="row"],
  .page-precios table.lc td:first-child{font-weight:600}
  .page-precios .table-wrap{overflow-x:auto}
</style>
