---
/** EN — 14 service sub-pages of the construction marketplace. */
import Layout from '../../../../layouts/Layout.astro';
import SchemaOrg from '../../../../components/seo/SchemaOrg.astro';
import ServicePage from '../../../../components/sector/ServicePage.astro';
import { sectorServiceSchema } from '../../../../lib/sector-schema';
import { ALL_SERVICES, serviceAlternates } from '../../../../data/sectores/construccion';
import type { SectorService } from '../../../../data/sectores/types';

export function getStaticPaths() {
  return ALL_SERVICES.map((svc) => ({ params: { slug: svc.slug.en }, props: { svc } }));
}

interface Props {
  svc: SectorService;
}
const { svc } = Astro.props;
const alternates = serviceAlternates(svc);
const c = svc.copy.en;
---

<Layout
  lang="en"
  title={c.seo.title}
  description={c.seo.description}
  path={alternates.en}
  alternates={alternates}
>
  <SchemaOrg slot="head" data={sectorServiceSchema('en', svc)} />
  <ServicePage lang="en" svc={svc} />
</Layout>
