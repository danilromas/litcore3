---
/**
 * Экран первого захода: тёмный холст + SVG-ядро (wireframe).
 * Показ: html.lc-splash-pending (ставит /lc-boot.js до paint).
 * Скрытие: kit.js (внешний бандл, CSP-safe). Без inline-скриптов.
 */
---

<div
  id="lc-splash"
  class="lc-splash"
  role="status"
  aria-live="polite"
  aria-busy="true"
  data-splash
>
  <div class="lc-splash__inner">
    <svg
      class="lc-splash__core"
      viewBox="0 0 120 120"
      width="88"
      height="88"
      aria-hidden="true"
      focusable="false"
    >
      <g class="lc-splash__wire" fill="none" stroke="currentColor" stroke-linejoin="round">
        <polygon points="60,8 104,34 104,86 60,112 16,86 16,34" stroke-width="1.25" opacity="0.55" />
        <polygon points="60,8 104,34 60,52 16,34" stroke-width="1" opacity="0.4" />
        <polygon points="60,52 104,34 104,86 60,112 16,86 16,34" stroke-width="1" opacity="0.35" />
        <line x1="60" y1="8" x2="60" y2="112" stroke-width="0.9" opacity="0.3" />
        <line x1="16" y1="34" x2="104" y2="86" stroke-width="0.9" opacity="0.25" />
        <line x1="104" y1="34" x2="16" y2="86" stroke-width="0.9" opacity="0.25" />
      </g>
      <circle class="lc-splash__dot" cx="60" cy="60" r="5.5" fill="currentColor" />
    </svg>
    <p class="lc-splash__brand">litcore<span>.ai</span></p>
    <div class="lc-splash__bar" aria-hidden="true"><span class="lc-splash__bar-fill"></span></div>
  </div>
</div>

<style is:global>
  .lc-splash {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: none;
    place-items: center;
    background: var(--lc-canvas, #0f151b);
    color: var(--lc-accent, #e8a33d);
    transition: opacity 420ms var(--lc-ease, cubic-bezier(0.22, 1, 0.36, 1)),
      visibility 420ms;
  }
  html.lc-splash-pending .lc-splash {
    display: grid;
  }
  html.lc-splash-pending .lc-splash.is-leaving,
  .lc-splash.is-done {
    display: none !important;
  }
  .lc-splash.is-leaving {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }
  .lc-splash__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
  }
  .lc-splash__core {
    display: block;
    color: var(--lc-accent, #e8a33d);
    filter: drop-shadow(0 0 18px rgba(232, 163, 61, 0.35));
    animation: lc-splash-spin 4.2s linear infinite;
  }
  .lc-splash__dot {
    animation: lc-splash-pulse 1.6s ease-in-out infinite;
  }
  .lc-splash__brand {
    margin: 0;
    font-family: var(--lc-font-text, 'Onest', sans-serif);
    font-weight: 800;
    font-size: 1.05rem;
    letter-spacing: -0.02em;
    color: var(--lc-glow-light, #eae6dc);
  }
  .lc-splash__brand span {
    color: var(--lc-canvas-muted, #a7b0b8);
    font-weight: 600;
  }
  .lc-splash__bar {
    width: 88px;
    height: 2px;
    border-radius: 1px;
    background: color-mix(in srgb, var(--lc-canvas-line, #2b3641) 80%, transparent);
    overflow: hidden;
  }
  .lc-splash__bar-fill {
    display: block;
    height: 100%;
    width: 0%;
    background: var(--lc-accent, #e8a33d);
    animation: lc-splash-progress 2.4s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  @keyframes lc-splash-spin {
    to {
      transform: rotate(360deg);
    }
  }
  @keyframes lc-splash-pulse {
    0%,
    100% {
      opacity: 0.55;
    }
    50% {
      opacity: 1;
    }
  }
  @keyframes lc-splash-progress {
    0% {
      width: 0%;
    }
    70% {
      width: 78%;
    }
    100% {
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lc-splash__core,
    .lc-splash__dot {
      animation: none;
    }
    .lc-splash__bar-fill {
      animation: none;
      width: 100%;
    }
  }
</style>
