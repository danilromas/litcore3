---
/** Шапка: бренд, меню, язык, CTA + мобильный drawer (гамбургер). */
import Core from './Core.astro';
import { NAV, HEADER_CTA, HOME_HREF, NAV_ARIA } from '../i18n/ui';
import type { Lang } from '../config/site';

interface Props {
  lang: Lang;
  /** Путь текущей страницы — для aria-current в меню */
  currentPath: string;
  /** Пути языковых альтернатив; нет — переключатель ведёт на главную языка */
  alternates?: Partial<Record<Lang, string>>;
}
const { lang, currentPath, alternates = {} } = Astro.props;

// Активный пункт: совпадение path (без якорей на главной — иначе все #секции «активны»)
const pathOnly = currentPath.split('#')[0] || currentPath;
const home = HOME_HREF[lang];
const active = NAV[lang]
  .filter((item) => {
    const hrefPath = item.href.split('#')[0] || '';
    if (!hrefPath) return false;
    // Якоря на главной не помечаем как current по path главной
    if (hrefPath === home || hrefPath === home.replace(/\/$/, '')) return false;
    return pathOnly === hrefPath || pathOnly.startsWith(hrefPath);
  })
  .sort((a, b) => b.href.split('#')[0].length - a.href.split('#')[0].length)[0];

const LANGS: Lang[] = ['es', 'ru', 'en'];
const cta = HEADER_CTA[lang];
const aria = NAV_ARIA[lang];
---

<header class="site-header" data-close-label={aria.close}>
  <div class="container nav">
    <a class="brand" href={HOME_HREF[lang]}
      ><Core sm text />litcore<span class="tld">.ai</span></a
    >

    <nav class="nav-links" aria-label={aria.main} data-nav-panel>
      {
        NAV[lang].map((item) => (
          <a href={item.href} aria-current={item === active ? 'page' : undefined}>
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="lang" aria-label={aria.lang} data-nav-lang>
      {
        LANGS.map((l) => (
          <a
            href={alternates[l] ?? HOME_HREF[l]}
            aria-current={l === lang ? 'true' : undefined}
            hreflang={l}
          >
            {l.toUpperCase()}
          </a>
        ))
      }
    </div>

    <a class="btn btn--primary nav-cta" href={cta.href}>{cta.label}</a>

    <button
      type="button"
      class="nav-toggle"
      aria-expanded="false"
      aria-controls="nav-drawer"
      aria-label={aria.menu}
      data-nav-toggle
    >
      <span class="nav-toggle__bars" aria-hidden="true"></span>
    </button>
  </div>

  <div class="nav-drawer" id="nav-drawer" hidden data-nav-drawer>
    <nav class="nav-drawer__links" aria-label={aria.main}>
      {
        NAV[lang].map((item) => (
          <a href={item.href} aria-current={item === active ? 'page' : undefined}>
            {item.label}
          </a>
        ))
      }
    </nav>
    <div class="nav-drawer__lang" aria-label={aria.lang}>
      {
        LANGS.map((l) => (
          <a
            href={alternates[l] ?? HOME_HREF[l]}
            aria-current={l === lang ? 'true' : undefined}
            hreflang={l}
          >
            {l.toUpperCase()}
          </a>
        ))
      }
    </div>
    <a class="btn btn--primary nav-drawer__cta" href={cta.href}>{cta.label}</a>
  </div>
</header>
