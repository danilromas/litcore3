---
/**
 * Линейные иконки услуг маркетплейса (24×24, stroke currentColor) —
 * в редакционном стиле litcore (тонкая линия, без заливки, цвет — акцент).
 * Ключ — id услуги из data/sectores/*.
 */
interface Props {
  id: string;
  /** Размер в px (по умолчанию 28) */
  size?: number;
}
const { id, size = 28 } = Astro.props;

const ICONS: Record<string, string> = {
  // №1 смета: документ с таблицей и суммой
  presupuestos:
    '<rect x="4" y="3" width="16" height="18" rx="2"/><path d="M8 7h8M8 11h8M8 15h4"/><circle cx="16" cy="16.5" r="1.6"/>',
  // №2 КП: документ-отправление
  propuestas:
    '<path d="M5 4h11l3 3v13a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1Z"/><path d="M15.5 4v3.5H19"/><path d="M8 12l3 3 5-6"/>',
  // №3 план-график: Gantt-полосы
  cronograma:
    '<rect x="3" y="4" width="18" height="16" rx="2"/><path d="M6 9h7M9 13h9M6 17h5"/>',
  // №4 фото-контроль: камера
  fotocontrol:
    '<path d="M4 8h3l2-2.5h6L17 8h3a1 1 0 0 1 1 1v9a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9a1 1 0 0 1 1-1Z"/><circle cx="12" cy="13" r="3.4"/>',
  // №5 нормы: щит с галочкой
  normas:
    '<path d="M12 3l7 3v5c0 4.6-3 8.4-7 10-4-1.6-7-5.4-7-10V6l7-3Z"/><path d="M9 12l2.2 2.2L15.5 10"/>',
  // №6 счета: чек-квитанция
  facturas:
    '<path d="M6 3h12v18l-2-1.4L14 21l-2-1.4L10 21l-2-1.4L6 21V3Z"/><path d="M9 8h6M9 12h6M9 16h3"/>',
  // №7 бот заявок: диалог
  'bot-solicitudes':
    '<path d="M4 5h16v11H9l-5 4V5Z"/><path d="M8 9h8M8 12.5h5"/>',
  // №8 мониторинг цен: график-тренд
  'precios-materiales':
    '<path d="M4 20V4"/><path d="M4 20h16"/><path d="M6.5 15.5l4-4 3 3 5.5-6"/><path d="M19 8.5V6h-2.5"/>',
  // №9 калькулятор
  calculadora:
    '<rect x="5" y="3" width="14" height="18" rx="2"/><path d="M8.5 7h7"/><path d="M9 12h.01M12 12h.01M15 12h.01M9 15.5h.01M12 15.5h.01M15 15.5h.01M9 19h.01M12 19h.01M15 19h.01" stroke-linecap="round"/>',
  // №10 Cowork: ядро с орбитой (мотив litcore)
  cowork:
    '<circle cx="12" cy="12" r="8"/><circle cx="12" cy="12" r="2.2" fill="currentColor" stroke="none"/><circle cx="18.4" cy="7.2" r="1.4" fill="currentColor" stroke="none"/>',
  // №11 совещания: микрофон
  reuniones:
    '<rect x="9.5" y="3" width="5" height="10" rx="2.5"/><path d="M6 11a6 6 0 0 0 12 0"/><path d="M12 17v4M9 21h6"/>',
  // №12 инфраструктура: стек-серверы
  infraestructura:
    '<rect x="4" y="4" width="16" height="6" rx="1.5"/><rect x="4" y="14" width="16" height="6" rx="1.5"/><path d="M7.5 7h.01M7.5 17h.01" stroke-linecap="round"/><path d="M17 10v4"/>',
  // №13 Telegram-CRM: бумажный самолёт
  'telegram-crm':
    '<path d="M21 4L3.5 11l5 2L19 6.5 10.5 14l.5 6 3-3.5 4 2.5L21 4Z"/>',
  // №14 сайты: глобус
  webs:
    '<circle cx="12" cy="12" r="8.5"/><path d="M3.5 12h17"/><path d="M12 3.5c2.6 2.3 3.9 5.1 3.9 8.5S14.6 18.2 12 20.5C9.4 18.2 8.1 15.4 8.1 12S9.4 5.8 12 3.5Z"/>',
};

const svg = ICONS[id] ?? ICONS.cowork;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={svg}
/>
